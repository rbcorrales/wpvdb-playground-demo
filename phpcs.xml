<?xml version="1.0"?>
<ruleset name="WPVDB Playground Demo">
	<description>PHPCS ruleset for the WPVDB Playground Demo plugin.</description>

	<rule ref="WordPress-Extra" />
	<rule ref="WordPress-Docs" />
	<rule ref="WordPress-VIP-Go">
		<exclude name="WordPressVIPMinimum.JS" />
	</rule>

	<rule ref="WordPress">
		<exclude name="Generic.Arrays.DisallowShortArraySyntax.Found" />
		<exclude name="Universal.Arrays.DisallowShortArraySyntax.Found" />
		<exclude name="Universal.Operators.DisallowStandalonePostIncrementDecrement.PostIncrementFound" />
	</rule>
	<rule ref="Generic.Arrays.DisallowLongArraySyntax" />

	<arg name="extensions" value="php" />
	<arg value="s" />

	<file>.</file>

	<exclude-pattern>*/.github/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/release/*</exclude-pattern>
</ruleset>
